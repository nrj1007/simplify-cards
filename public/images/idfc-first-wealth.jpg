        var w = window.innerWidth;
        var mobile  = "";
        var tablet  = "";
        var desktop = "";

        var href;
        if (w <= 576 && mobile) {
          href = mobile;
        } else if (w >= 576 && w < 1200 && tablet) {
          href = tablet;
        } else if (w >= 1200 && desktop) {
          href = desktop;
        }

        if (href) {
          var link = document.createElement('link');
          link.rel           = 'preload';
          link.as            = 'image';
          link.href          = href;
          link.fetchPriority = 'high';
          document.head.appendChild(link);
        }
    </script>

    
    
