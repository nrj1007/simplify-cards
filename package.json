{
  "name": "card-ai-india",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "validate:cards": "tsc --module commonjs --target es2020 --esModuleInterop --resolveJsonModule --skipLibCheck --outDir .tmp scripts/validate-cards.ts && node .tmp/scripts/validate-cards.js",
    "draft:lounge": "tsc --module commonjs --target es2020 --esModuleInterop --resolveJsonModule --skipLibCheck --outDir .tmp scripts/draft-lounge.ts && node .tmp/scripts/draft-lounge.js",
    "draft:milestones": "tsc --module commonjs --target es2020 --esModuleInterop --resolveJsonModule --skipLibCheck --outDir .tmp scripts/draft-milestones.ts && node .tmp/scripts/draft-milestones.js",
    "draft:joining-renewal": "tsc --module commonjs --target es2020 --esModuleInterop --resolveJsonModule --skipLibCheck --outDir .tmp scripts/draft-joining-renewal.ts && node .tmp/scripts/draft-joining-renewal.js",
    "score:popularity": "node scripts/update-popularity-scores.js",
    "ingest:technofino-content": "node scripts/ingest-technofino-content.js",
    "fetch:telegram-inbox": "node scripts/fetch-telegram-inbox.js"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "16.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "eslint": "9.17.0",
    "eslint-config-next": "16.2.6",
    "typescript": "5.7.2",
    "vitest": "^4.1.5"
  }
}
